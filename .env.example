# Copy this file to `.env` and fill in your own values.
# `.env` is git-ignored and is NEVER committed or shared.

# --- Agent brain: Groq (free tier, no card) -> https://console.groq.com ---
GROQ_API_KEY=

# --- Speech: Deepgram STT + Aura TTS (free $200 credit) -> https://console.deepgram.com ---
DEEPGRAM_API_KEY=

# --- Booking database (SQLAlchemy URL). Default = local SQLite file. ---
DATABASE_URL=sqlite:///voicestream.db
#
# To use Supabase (hosted Postgres) instead, set DATABASE_URL to your
# Supabase connection string. In the Supabase dashboard:
#   Project -> Connect: copy the "Session pooler" URI
#   (IPv4-friendly, port 5432). It looks like:
#
#   DATABASE_URL=postgresql://postgres.<project-ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
#
# Notes:
#   - URL-encode special characters in the password (@ -> %40, etc.).
#   - `postgres://` is auto-normalised to `postgresql://`, so pasting
#     Supabase's raw URI also works.
#   - Keep `?sslmode=require` (Supabase requires SSL).
#   - Prefer the Session pooler for this long-running server. The
#     Transaction pooler (port 6543) is for serverless/short-lived conns.
#   - Feature 4: point this at the SAME Supabase project AIVA uses, so both
#     services share one booking_requests table.

# --- TURN server (REQUIRED for callers on a different network / NAT) ---
# Without TURN, the page loads through ngrok but WebRTC audio is P2P UDP
# and won't traverse arbitrary NATs (your Kenyan tester will hear nothing).
# Both the server AND the browser client read these via /api/ice_servers.
#
# Quick zero-signup option (free anonymous endpoint, fine for dev/test):
#   TURN_URLS=turn:openrelay.metered.ca:80,turn:openrelay.metered.ca:443,turn:openrelay.metered.ca:443?transport=tcp
#   TURN_USERNAME=openrelayproject
#   TURN_CREDENTIAL=openrelayproject
#
# Recommended for reliability (free tier with personal credentials):
#   Sign up at https://www.metered.ca/ or https://www.expressturn.com/
#   (50+ GB/month free), or use Cloudflare Realtime TURN.
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=

# --- Optional: server port (server + scripts/tunnel.py). Default 8000. ---
# PORT=8000

# --- Optional: expose the local server via ngrok (scripts/tunnel.py) ---
# Free token: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# --- Optional: voice defaults (server reads from env at startup) ---
# LLM_MODEL=llama-3.3-70b-versatile
# STT_MODEL=nova-3
# TTS_VOICE=aura-2-thalia-en
# BUSINESS_NAME=City Care Hospital

# --- Deploy-only (read by scripts/deploy_vps.sh; NOT used at runtime) ---
# DuckDNS token, used to auto-update callbot.duckdns.org -> this VPS's IP
# and to install a 5-minute cron that keeps it in sync. Leave blank to
# skip; point DNS to the VPS manually instead.
# Token shown at https://www.duckdns.org after sign-in.
DUCKDNS_TOKEN=

# Email for Let's Encrypt expiry notices. Required for certbot to issue
# a TLS cert during deploy. Leave blank to skip TLS (server runs on :80).
LE_EMAIL=
